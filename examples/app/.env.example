SONIOX_API_KEY=<SONIOX_API_KEY>

# Optional: regional deployment. Leave unset for US.
# 'eu' -> *.eu.soniox.com, 'jp' -> *.jp.soniox.com.
# The /tmp-key route echoes this value to the browser so the client SDK
# connects to the matching regional endpoints.
# SONIOX_REGION=eu

# Optional: explicit base domain override (alternative to SONIOX_REGION).
# Useful for custom / staging deployments.
# SONIOX_BASE_DOMAIN=eu.soniox.com
